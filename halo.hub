-- PHASE 1: CORE STATE, FLAGS, ESP, DATA, HELPERS
-- ══════════════════════════════════════════════════════════════
local TweenService = game:GetService("TweenService")
local HttpService  = game:GetService("HttpService")
local UIS          = UserInputService
local plr          = Player
local Running      = true

local Flags = {
    BoxESP=false, Tracer=false, ESPName=false, ESPDist=false,
    ESPHPBar=false, ESPWeapon=false, ESPSkeleton=false, ESPMasak=false,
    TPNoClip=false, InvScan=false, InstantInteract=false,
    InfStamina=false, HybridSpeed=false, AuraKill=false, AutoCook=false,
}
local BoxESPMode    = "CORNER"
local ESPMaxDist    = 800
local TracerMaxDist = 400
local BlinkMode     = "PC"

-- ── ESP Object Pool ──────────────────────────────────────────
local ESP = {}
local SKEL_BONES = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"RightUpperLeg","LeftUpperLeg"},
}

local function _makeLine(t,c) local l=Drawing.new("Line");l.Thickness=t;l.Color=c;l.Visible=false;return l end
local function _makeText(s,c,ctr) local t=Drawing.new("Text");t.Size=s;t.Color=c;t.Center=ctr;t.Outline=true;t.Visible=false;return t end
local function _makeSquare() local s=Drawing.new("Square");s.Thickness=1;s.Filled=false;s.Visible=false;return s end

local function createESP(p)
    if p==plr or ESP[p] then return end
    local e={
        box=_makeSquare(),
        corners={},skeleton={},
        tracer=_makeLine(1,Color3.new(1,1,1)),
        dispname=_makeText(14,Color3.new(1,1,1),true),
        username=_makeText(12,Color3.fromRGB(180,180,180),true),
        dist=_makeText(12,Color3.new(1,1,1),true),
        weapon=_makeText(12,Color3.fromRGB(255,220,80),true),
        masak=_makeText(14,Color3.fromRGB(0,255,100),false),
        hpbg=Drawing.new("Square"), hpbar=Drawing.new("Square"),
        hpnum=_makeText(11,Color3.new(0,1,0),false),
    }
    e.hpbg.Filled=false;e.hpbg.Thickness=1;e.hpbg.Visible=false
    e.hpbar.Filled=true;e.hpbar.Visible=false
    for i=1,8 do e.corners[i]=_makeLine(1.5,Color3.new(1,1,1)) end
    for i=1,#SKEL_BONES do e.skeleton[i]=_makeLine(1.2,Color3.new(1,1,1)) end
    ESP[p]=e
end

local function _hideESP(e)
    e.box.Visible=false;e.tracer.Visible=false
    e.dispname.Visible=false;e.username.Visible=false
    e.dist.Visible=false;e.weapon.Visible=false;e.masak.Visible=false
    e.hpbg.Visible=false;e.hpbar.Visible=false;e.hpnum.Visible=false
    for i=1,8 do e.corners[i].Visible=false end
    for i=1,#SKEL_BONES do e.skeleton[i].Visible=false end
end

local function removeESP(p)
    local e=ESP[p]; if not e then return end
    pcall(function()
        e.box:Remove();e.tracer:Remove()
        e.dispname:Remove();e.username:Remove();e.dist:Remove()
        e.weapon:Remove();e.masak:Remove()
        e.hpbg:Remove();e.hpbar:Remove();e.hpnum:Remove()
        for i=1,8 do e.corners[i]:Remove() end
        for i=1,#SKEL_BONES do e.skeleton[i]:Remove() end
    end)
    ESP[p]=nil
end

for _,p in pairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)

-- ── ESP Cache (throttled inventory scan) ─────────────────────
local espCache = {}
local ESP_MASAK_KW = {"water","sugar","gelatin","marshmallow"}
local lastESPScan = 0
RunService.Heartbeat:Connect(function()
    if not Running then return end
    local now=tick(); if now-lastESPScan<0.5 then return end; lastESPScan=now
    for p in pairs(ESP) do
        local ch=p.Character; local hb,wn=false,nil
        pcall(function()
            local function scanBag(bag) if not bag then return end
                for _,v in pairs(bag:GetChildren()) do if v:IsA("Tool") then
                    local n=v.Name:lower()
                    for _,kw in ipairs(ESP_MASAK_KW) do if n:find(kw) then hb=true return end end
                end end
            end
            scanBag(p.Backpack); if ch then scanBag(ch) end
            if ch then for _,v in pairs(ch:GetChildren()) do
                if v:IsA("Tool") then local n=v.Name:lower(); local isB=false
                    for _,kw in ipairs(ESP_MASAK_KW) do if n:find(kw) then isB=true break end end
                    if not isB then wn=v.Name end
                end
            end end
        end)
        espCache[p]={hasBahan=hb,wName=wn}
    end
    for p in pairs(espCache) do if not p or not p.Parent then espCache[p]=nil end end
end)

