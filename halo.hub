-- MISC LOGIC: Stamina, Speed, Aura, Blink, Instant Interact
-- ══════════════════════════════════════════════════════════════

-- Instant Interact
game:GetService("ProximityPromptService").PromptShown:Connect(function(prompt)
    if Flags.InstantInteract then pcall(function() if prompt.HoldDuration>0 then prompt.HoldDuration=0.05 end end) end
end)

-- Infinite Stamina
local staminaConns={}
local function detachStamina() for _,c in ipairs(staminaConns) do pcall(function() c:Disconnect() end) end; staminaConns={} end
local function attachStamina(char)
    detachStamina(); if not char then return end; task.wait(0.6)
    local hum=char:FindFirstChildOfClass("Humanoid")
    pcall(function()
        local bar=plr.PlayerGui.Main.StaminaBar.Bar;local maxSize=bar.Size;local blocking=false
        local c1=bar:GetPropertyChangedSignal("Size"):Connect(function()
            if not Flags.InfStamina or blocking then return end
            if bar.Size.X.Scale>maxSize.X.Scale then maxSize=bar.Size
            elseif bar.Size.X.Scale<maxSize.X.Scale then blocking=true;bar.Size=maxSize;blocking=false end
        end)
        table.insert(staminaConns,c1)
    end)
    if hum then
        local SPRINT_SPEED=hum.WalkSpeed;task.spawn(function() task.wait(0.5);SPRINT_SPEED=math.max(SPRINT_SPEED,hum.WalkSpeed) end)
        local blocking2=false
        local c2=hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if not Flags.InfStamina or blocking2 then return end
            local state=hum:GetState()
            if (state==Enum.HumanoidStateType.Running or state==Enum.HumanoidStateType.RunningNoPhysics) and hum.WalkSpeed<SPRINT_SPEED*0.85 then
                blocking2=true;hum.WalkSpeed=SPRINT_SPEED;blocking2=false end
            if hum.WalkSpeed>SPRINT_SPEED then SPRINT_SPEED=hum.WalkSpeed end
        end)
        table.insert(staminaConns,c2)
    end
    pcall(function()
        char:SetAttribute("CanRun",true)
        local c3=char:GetAttributeChangedSignal("CanRun"):Connect(function()
            if Flags.InfStamina and char:GetAttribute("CanRun")==false then task.defer(function() pcall(function() char:SetAttribute("CanRun",true) end) end) end
        end)
        table.insert(staminaConns,c3)
    end)
end
task.spawn(function() local last=Flags.InfStamina; while Running do task.wait(0.2)
    if Flags.InfStamina~=last then last=Flags.InfStamina; if last then attachStamina(plr.Character) else detachStamina() end end
end; detachStamina() end)
plr.CharacterAdded:Connect(function(char) if Flags.InfStamina then attachStamina(char) end end)

-- Hybrid Speed
RunService.Heartbeat:Connect(function(dt)
    if not Flags.HybridSpeed then return end
    local char=plr.Character;local hum=char and char:FindFirstChildOfClass("Humanoid");local root=char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    if hum.WalkSpeed~=22 then hum.WalkSpeed=22 end
    if hum.MoveDirection.Magnitude>0 then root.CFrame=root.CFrame+hum.MoveDirection*3*dt end
end)
task.spawn(function() local lastHS=Flags.HybridSpeed; while Running do task.wait(0.15)
    if Flags.HybridSpeed~=lastHS then lastHS=Flags.HybridSpeed; if not lastHS then pcall(function() local h=plr.Character and plr.Character:FindFirstChildOfClass("Humanoid"); if h then h.WalkSpeed=16 end end) end end
end end)

-- Aura Kill / NoClip
local auraChanged={}; local auraRunning=false; local auraWatcher=nil
local function isWall(part) local s=part.Size;local name=part.Name:lower();local pn=(part.Parent and part.Parent.Name or ""):lower()
    if pn:find("subway") then return false end
    if name:find("stair") or name:find("step") or name:find("floor") or name:find("ground") or name:find("ramp") then return false end
    if s.Y<s.X*0.25 and s.Y<s.Z*0.25 then return false end; return true
end
local function applyPart(v) if not(v and v:IsA("BasePart") and v.CanCollide) then return end; if not isWall(v) then return end
    local isChar=false; for _,p in pairs(Players:GetPlayers()) do if p.Character and v:IsDescendantOf(p.Character) then isChar=true break end end
    if not isChar then table.insert(auraChanged,v);pcall(function() v.CanCollide=false;v.CanQuery=false end) end
end
local function enableAura() auraChanged={};auraRunning=true
    local parts=workspace:GetDescendants();local CHUNK=80
    task.spawn(function() local i=1; while i<=#parts and auraRunning do for j=i,math.min(i+CHUNK-1,#parts) do applyPart(parts[j]) end; i=i+CHUNK; task.wait() end end)
    auraWatcher=workspace.DescendantAdded:Connect(function(obj) if auraRunning then task.wait();applyPart(obj) end end)
end
local function disableAura() auraRunning=false; if auraWatcher then auraWatcher:Disconnect();auraWatcher=nil end
    local parts=auraChanged;auraChanged={};local CHUNK=80
    task.spawn(function() local i=1; while i<=#parts do for j=i,math.min(i+CHUNK-1,#parts) do local v=parts[j];pcall(function() if v and v.Parent then v.CanCollide=true;v.CanQuery=true end end) end; i=i+CHUNK; task.wait() end end)
end
task.spawn(function() local last=Flags.AuraKill; while Running do task.wait(0.3)
    if Flags.AuraKill~=last then last=Flags.AuraKill; if last then enableAura() else disableAura() end end
end; disableAura() end)

-- Blink TP [T]
UIS.InputBegan:Connect(function(input,processed)
    if Flags.TPNoClip and BlinkMode=="PC" and input.KeyCode==Enum.KeyCode.T then
        local hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if hrp then TweenService:Create(hrp,TweenInfo.new(0.15,Enum.EasingStyle.Linear),{CFrame=hrp.CFrame*CFrame.new(0,0,-6)}):Play() end
    end
end)

-- Vehicle Fly state
local vFlyActive=false; local vFlySpeed=50; local vLockedCF=nil; local vFlyLoop=nil
local function vStopFly() vLockedCF=nil; if vFlyLoop then vFlyLoop:Disconnect();vFlyLoop=nil end
    local hum=plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
    if hum then Camera.CameraSubject=hum;Camera.CameraType=Enum.CameraType.Custom end
end
local function vStartFly() vStopFly()
    vFlyLoop=RunService.Heartbeat:Connect(function(dt)
        local hum=plr.Character and plr.Character:FindFirstChildOfClass("Humanoid");local seat=hum and hum.SeatPart
        if seat then
            local vehicle=seat:FindFirstAncestorOfClass("Model");local vRoot=(vehicle and vehicle.PrimaryPart) or seat
            if not vLockedCF then vLockedCF=vRoot.CFrame end
            local dir=Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W) then dir=dir+Camera.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then dir=dir-Camera.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then dir=dir-Camera.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then dir=dir+Camera.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.E) then dir=dir+Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.Q) then dir=dir-Vector3.new(0,1,0) end
            if dir.Magnitude>0 then dir=dir.Unit end
            vLockedCF=CFrame.new(vLockedCF.Position+(dir*vFlySpeed*dt))*vLockedCF.Rotation
            vRoot.CFrame=vLockedCF;vRoot.AssemblyLinearVelocity=Vector3.zero;vRoot.AssemblyAngularVelocity=Vector3.zero
        else if vFlyActive then vFlyActive=false;vStopFly() end end
    end)
end

