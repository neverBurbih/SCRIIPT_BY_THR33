    TertiaryBackground  = Color3.fromRGB(20, 20, 20),
    Border              = Color3.fromRGB(20, 20, 20),
    Outline             = Color3.fromRGB(20, 20, 20),
    Stroke              = Color3.fromRGB(20, 20, 20),
    TextColor           = Color3.fromRGB(255, 255, 255),
    SubTextColor        = Color3.fromRGB(180, 180, 180),
}
for key, color in pairs(HaloHubTheme) do
    if Library.Theme[key] ~= nil then Library.Theme[key] = color end
end

