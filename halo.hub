    Name      = "Halo Hub",
    Version   = "v1.0",
    Logo      = "93007870315593",
    FadeSpeed = 0.25,
})

local KeybindList = Library:KeybindsList()
KeybindList:SetVisibility(false)

task.defer(function()
    task.wait(0.2)
    for key, color in pairs(HaloHubTheme) do
        pcall(function() Library:ChangeTheme(key, color) end)
    end
end)

