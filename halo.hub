-- ── Auto Cook ────────────────────────────────────────────────
local totalMasak=0; local currentCookStep=1
local lastCookProgressTime=0; local COOK_WATCHDOG_SECS=150
local cookSteps={
    {keyword="water",baseWait=20},
    {multi={{keyword="sugar",wait=1.5},{keyword="gelatin",wait=45}}},
    {keyword="empty",baseWait=2},
}

local CookSection = FarmSub:Section({Name="Auto Cook",Icon="103174889897193",Side=1})
CookSection:Toggle({Name="Auto Cook",Flag="AutoCook",Default=false,Callback=function(v)
    Flags.AutoCook=v
    if v then
        lastCookProgressTime=tick()
        if selectedApart and selectedApart.cx then task.spawn(snapToCookPos) end
    end
end})
CookSection:Button({Name="Reset Cook Counter",Callback=function() totalMasak=0;currentCookStep=1 end})

-- Auto Cook Loop
task.spawn(function()
    while Running do
        task.wait(math.random(10,20)/100)
        if Flags.AutoCook then
            if lastCookProgressTime>0 and (tick()-lastCookProgressTime)>COOK_WATCHDOG_SECS then
                currentCookStep=1;lastCookProgressTime=tick();task.wait(1.5)
            end
            local data=cookSteps[currentCookStep]
            local ch=plr.Character;local hum=ch and ch:FindFirstChildOfClass("Humanoid")
            local function findTool(keyword)
                local t=nil
                for i=1,6 do
                    if not Flags.AutoCook or not Running then break end
                    if plr.Backpack then for _,v in pairs(plr.Backpack:GetChildren()) do
                        if string.find(string.lower(v.Name),keyword) then t=v break end end end
                    if not t and plr.Character then for _,v in pairs(plr.Character:GetChildren()) do
                        if v:IsA("Tool") and string.find(string.lower(v.Name),keyword) then t=v break end end end
                    if t then break end;task.wait(0.2)
                end
                return t
            end
            local function doOneBahan(keyword,waitTime)
                local hm=plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
                local tool=findTool(keyword); if not tool or not hm then return false end
                if selectedApart and selectedApart.cx then snapToCookPos();task.wait(0.15) end
                task.wait(math.random(1,2)/10);hm:EquipTool(tool);task.wait(math.random(1,2)/10)
                local prompt=findCookPrompt(); if prompt then triggerPrompt(prompt);task.wait(math.random(1,2)/10) end
                if isCasinoApart() then snapToTopPos() end
                local tw2=0;local hw=waitTime+(math.random(1,5)/10)
                while tw2<hw and Flags.AutoCook and Running do local mw=math.random(3,5)/10;task.wait(mw);tw2=tw2+mw end
                return true
            end
            if data.multi then
                local allOk=true
                for _,sub in ipairs(data.multi) do
                    if not Flags.AutoCook or not Running then allOk=false break end
                    local ok=doOneBahan(sub.keyword,sub.wait)
                    if not ok then Flags.AutoCook=false;allOk=false break end
                end
                if allOk and Flags.AutoCook and Running then
                    currentCookStep=currentCookStep+1
                    if currentCookStep>#cookSteps then currentCookStep=1 end
                    lastCookProgressTime=tick()
                end
            else
                if selectedApart and selectedApart.cx then snapToCookPos();task.wait(0.15) end
                local tool=findTool(data.keyword)
                if tool and hum then
                    task.wait(math.random(1,2)/10);hum:EquipTool(tool);task.wait(math.random(1,2)/10)
                    local prompt=findCookPrompt()
                    if prompt then
                        triggerPrompt(prompt);task.wait(math.random(1,2)/10)
                        if data.keyword=="empty" then task.wait(math.random(1,2)/10)
                            local prompt2=findCookPrompt(); if prompt2 then triggerPrompt(prompt2) end end
                    end
                    if isCasinoApart() and data.keyword~="empty" then snapToTopPos() end
                    local hw=data.baseWait+(math.random(1,5)/10);local tw2=0
                    while tw2<hw and Flags.AutoCook and Running do local mw=math.random(3,5)/10;task.wait(mw);tw2=tw2+mw end
                    if Flags.AutoCook and Running then
                        if data.keyword=="empty" then totalMasak=totalMasak+1 end
                        currentCookStep=currentCookStep+1
                        if currentCookStep>#cookSteps then currentCookStep=1 end
                        lastCookProgressTime=tick()
                    end
                else Flags.AutoCook=false end
            end
        end
    end
end)

-- ── Auto Buy ─────────────────────────────────────────────────
local AutoBuyAmount=10
local BuySection = FarmSub:Section({Name="Auto Buy — Lamont Bell",Icon="103174889897193",Side=2})
BuySection:Slider({Name="Buy Quantity",Flag="BuyQty",Min=1,Max=100,Default=10,Suffix="x",Decimals=1,Callback=function(v) AutoBuyAmount=math.floor(v) end})

local function doRemoteBuy(itemNames,qty)
    local RS2=game:GetService("ReplicatedStorage")
    local remEvts=RS2:FindFirstChild("RemoteEvents");local spRE=remEvts and remEvts:FindFirstChild("StorePurchase")
    if not spRE then return end
    for _,itemName in ipairs(itemNames) do
        for i=1,qty do pcall(function() spRE:FireServer(itemName,1) end);task.wait(0.4) end
        task.wait(0.3)
    end
end

BuySection:Button({Name="Buy PACK (Water+Sugar+Gelatin)",Callback=function() task.spawn(function() doRemoteBuy({"Water","Sugar Block Bag","Gelatin"},AutoBuyAmount) end) end})
BuySection:Button({Name="Buy WATER only",Callback=function() task.spawn(function() doRemoteBuy({"Water"},AutoBuyAmount) end) end})
BuySection:Button({Name="Buy SUGAR only",Callback=function() task.spawn(function() doRemoteBuy({"Sugar Block Bag"},AutoBuyAmount) end) end})
BuySection:Button({Name="Buy GELATIN only",Callback=function() task.spawn(function() doRemoteBuy({"Gelatin"},AutoBuyAmount) end) end})

-- ── Auto Sell Marshmallow ────────────────────────────────────
local SellSection = FarmSub:Section({Name="Auto Sell",Icon="103174889897193",Side=2})
SellSection:Button({Name="Sell All Marshmallow",Callback=function()
    task.spawn(function()
        local function getMarshmallows()
            local list={}
            if plr.Backpack then for _,v in pairs(plr.Backpack:GetChildren()) do
                if v:IsA("Tool") and v.Name:lower():find("marshmallow") then table.insert(list,v) end end end
            if plr.Character then for _,v in pairs(plr.Character:GetChildren()) do
                if v:IsA("Tool") and v.Name:lower():find("marshmallow") then table.insert(list,v) end end end
            return list
        end
        local marshmallows=getMarshmallows(); if #marshmallows==0 then return end
        -- Find sell prompt
        local sellPrompt=nil;local hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _,obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") and obj.ActionText:lower():find("interact") then
                    local pos=getPromptPosition(obj); if pos and (pos-hrp.Position).Magnitude<30 then sellPrompt=obj break end
                end
            end
        end
        if not sellPrompt then return end
        pcall(function() sellPrompt.MaxActivationDistance=9999;sellPrompt.RequiresLineOfSight=false end)
        for _,marsh in ipairs(marshmallows) do
            local hum2=plr.Character and plr.Character:FindFirstChildOfClass("Humanoid"); if not hum2 then break end
            pcall(function() hum2:EquipTool(marsh) end);task.wait(0.08)
            pcall(function() fireproximityprompt(sellPrompt) end);task.wait(0.18)
        end
        pcall(function() if sellPrompt and sellPrompt.Parent then sellPrompt.MaxActivationDistance=10;sellPrompt.RequiresLineOfSight=true end end)
    end)
end})

-- ── Auto Farm Box ────────────────────────────────────────────
local boxActive=false
local BOX_POS_A=CFrame.new(-551.47,3.54,-84.97); local BOX_POS_B=CFrame.new(-401.96,3.36,-70.98)

local BoxSection = FarmSub:Section({Name="Auto Farm Box",Icon="103174889897193",Side=2})
BoxSection:Toggle({Name="Auto Farm Box",Flag="AutoBox",Default=false,Callback=function(v)
    boxActive=v
    if v then task.spawn(function()
        while boxActive and Running do
            local ch=plr.Character;local hum=ch and ch:FindFirstChildOfClass("Humanoid")
            if not ch or not hum or hum.Health<=0 then
                local newChar=plr.CharacterAdded:Wait();newChar:WaitForChild("HumanoidRootPart",10);task.wait(1)
                if not boxActive then break end
            end
            -- Step 1: tween to A
            local hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist=(hrp.Position-BOX_POS_A.Position).Magnitude
                local tw=TweenService:Create(hrp,TweenInfo.new(math.max(dist/20,0.05),Enum.EasingStyle.Linear),{CFrame=BOX_POS_A})
                tw:Play();tw.Completed:Wait()
            end
            if not boxActive then break end;task.wait(0.3)
            -- Step 2: fire prompt at A
            local promptA=nil
            for _,obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local pos=getPromptPosition(obj); if pos and (pos-BOX_POS_A.Position).Magnitude<20 then promptA=obj break end
                end
            end
            if promptA then triggerPrompt(promptA) end;task.wait(0.5)
            if not boxActive then break end
            -- Step 3: tween to B
            hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist2=(hrp.Position-BOX_POS_B.Position).Magnitude
                local tw2=TweenService:Create(hrp,TweenInfo.new(math.max(dist2/20,0.05),Enum.EasingStyle.Linear),{CFrame=BOX_POS_B})
                tw2:Play();tw2.Completed:Wait()
            end
            if not boxActive then break end;task.wait(0.3)
            -- Step 4: equip crate + fire prompt at B
            local hum2=plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
            if hum2 then
                local crate=plr.Backpack:FindFirstChild("Crate") or plr.Backpack:FindFirstChild("crate")
                if crate then pcall(function() hum2:EquipTool(crate) end) end
            end
            task.wait(0.3)
            local promptB=nil
            for _,obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local pos=getPromptPosition(obj); if pos and (pos-BOX_POS_B.Position).Magnitude<20 then promptB=obj break end
                end
            end
            if promptB then triggerPrompt(promptB) end;task.wait(0.5)
        end
        boxActive=false
    end) end
end})

-- ══════════════════════════════════════════════════════════════
-- FULLY AUTO FARM — Loop: Kill TP → Buy → Cook → Sell → Repeat
-- ══════════════════════════════════════════════════════════════
local MARSH_X,MARSH_Y,MARSH_Z = 510.38,3.59,603.50
local AF = {active=false, paused=false, packQty=10, phase=""}

local AFSection = FarmSub:Section({Name="Fully Auto Farm",Icon="103174889897193",Side=1})
AFSection:Label("Pilih apartment dulu sebelum ON","Left")
AFSection:Slider({Name="Pack per Siklus",Flag="AFPackQty",Min=1,Max=100,Default=10,Suffix="x",Decimals=1,Callback=function(v) AF.packQty=math.floor(v) end})
AFSection:Toggle({Name="Fully Auto Farm",Flag="FullyAutoFarm",Default=false,Callback=function(v)
    if v then
        if not selectedApart then AF.active=false return end
        AF.active=true; AF.paused=false
        task.spawn(function()
            local cycleCount=0; local needsKillTP=true; local AF_died=false; local isDoingKillTP=false
            local deathConn=plr.CharacterAdded:Connect(function()
                if not isDoingKillTP and AF.active then AF_died=true end
            end)

            -- Sell helper
            local function afDoSell()
                local sellP=nil;local hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if hrp then for _,obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") and obj.ActionText:lower():find("interact") then
                        local pos=getPromptPosition(obj); if pos and (pos-hrp.Position).Magnitude<30 then sellP=obj break end
                    end
                end end
                if not sellP then task.wait(1.5) return end
                pcall(function() sellP.MaxActivationDistance=9999;sellP.RequiresLineOfSight=false end)
                local list={}
                if plr.Backpack then for _,v2 in pairs(plr.Backpack:GetChildren()) do
                    if v2:IsA("Tool") and v2.Name:lower():find("marshmallow") then table.insert(list,v2) end end end
                if plr.Character then for _,v2 in pairs(plr.Character:GetChildren()) do
                    if v2:IsA("Tool") and v2.Name:lower():find("marshmallow") then table.insert(list,v2) end end end
                for _,marsh in ipairs(list) do
                    if not AF.active then break end
                    while AF.paused and AF.active do task.wait(0.3) end
                    local hum2=plr.Character and plr.Character:FindFirstChildOfClass("Humanoid"); if not hum2 then break end
                    pcall(function() hum2:EquipTool(marsh) end);task.wait(0.08)
                    pcall(function() fireproximityprompt(sellP) end);task.wait(0.18)
                end
                pcall(function() if sellP and sellP.Parent then sellP.MaxActivationDistance=10;sellP.RequiresLineOfSight=true end end)
            end

            -- Buy pack helper
            local function afDoBuyPack(qty)
                local RS2=game:GetService("ReplicatedStorage")
                local remEvts=RS2:FindFirstChild("RemoteEvents");local spRE=remEvts and remEvts:FindFirstChild("StorePurchase")
                if not spRE then return end
                local packItems={"Water","Sugar Block Bag","Gelatin"}
                for _,item in ipairs(packItems) do
                    if not AF.active then break end
                    for i=1,qty do
                        if not AF.active then break end
                        while AF.paused and AF.active do task.wait(0.3) end
                        pcall(function() spRE:FireServer(item,1) end);task.wait(0.4)
                    end
                    task.wait(0.3)
                end
                task.wait(1)
            end

            -- Main loop
            while AF.active and Running do
                AF_died=false

                -- PHASE 1: Kill TP → Buy Marshmallow location
                if needsKillTP then
                    isDoingKillTP=true
                    AF.phase="Phase 1 · Kill TP → Buy Marshmallow..."
                    doSuicideTP({name="Buy Marshmallow",x=MARSH_X,y=MARSH_Y,z=MARSH_Z})
                    isDoingKillTP=false; needsKillTP=false
                end
                while AF.paused and AF.active do task.wait(0.3) end
                if not AF.active then break end
                if AF_died then needsKillTP=true;task.wait(1);continue end

                -- PHASE 2: Buy Pack
                AF.phase="Phase 2 · Buy Pack x"..AF.packQty.."..."
                afDoBuyPack(AF.packQty)
                while AF.paused and AF.active do task.wait(0.3) end
                if not AF.active then break end
                if AF_died then needsKillTP=true;task.wait(1);continue end

                -- PHASE 3: TP → Apartment
                local apt=selectedApart; if not apt then AF.active=false break end
                AF.phase="Phase 3 · TP → "..apt.name.."..."
                tpToPos(apt.x,apt.y,apt.z)
                local wl=0; while tpActive and wl<100 do task.wait(0.1);wl=wl+1 end; task.wait(0.5)
                while AF.paused and AF.active do task.wait(0.3) end
                if not AF.active then break end
                if AF_died then needsKillTP=true;task.wait(1);continue end
                snapToCookPos();task.wait(0.5)

                -- PHASE 4: Auto Cook until qty done
                local startMasak=totalMasak; local target=startMasak+AF.packQty
                local afLastMasak=totalMasak; local afLastMasakTime=tick()
                Flags.AutoCook=true; lastCookProgressTime=tick()
                AF.phase="Phase 4 · Cook 0/"..AF.packQty.."..."

                while AF.active and Running and totalMasak<target do
                    if AF_died then break end
                    if AF.paused then
                        if Flags.AutoCook then Flags.AutoCook=false end
                        while AF.paused and AF.active do task.wait(0.3) end
                        if not AF.active then break end
                        Flags.AutoCook=true;lastCookProgressTime=tick();snapToCookPos()
                    end
                    if totalMasak>afLastMasak then afLastMasak=totalMasak;afLastMasakTime=tick()
                    elseif (tick()-afLastMasakTime)>COOK_WATCHDOG_SECS then
                        currentCookStep=1;lastCookProgressTime=tick();afLastMasakTime=tick()
                        snapToCookPos();task.wait(1)
                    end
                    local done=totalMasak-startMasak
                    AF.phase="Phase 4 · Cook "..done.."/"..AF.packQty.."..."
                    task.wait(0.5)
                end
                Flags.AutoCook=false
                while AF.paused and AF.active do task.wait(0.3) end
                if not AF.active then break end
                if AF_died then needsKillTP=true;task.wait(1);continue end

                -- PHASE 5: TP → Marshmallow (for sell)
                AF.phase="Phase 5 · TP → Buy Marshmallow (sell)..."
                tpToPos(MARSH_X,MARSH_Y,MARSH_Z);task.wait(0.5)
                while AF.paused and AF.active do task.wait(0.3) end
                if not AF.active then break end
                if AF_died then needsKillTP=true;task.wait(1);continue end

                -- PHASE 6: Sell All
                AF.phase="Phase 6 · Sell Marshmallow..."
                afDoSell();task.wait(0.5)
                while AF.paused and AF.active do task.wait(0.3) end
                if not AF.active then break end
                if AF_died then needsKillTP=true;task.wait(1);continue end

                -- Cycle complete
                cycleCount=cycleCount+1
                AF.phase="Siklus #"..cycleCount.." selesai! Looping..."
                task.wait(0.8)
            end

            -- cleanup
            if deathConn then deathConn:Disconnect() end
            AF.active=false;AF.paused=false;Flags.AutoCook=false
            AF.phase=""
        end)
    else
        AF.active=false;AF.paused=false;Flags.AutoCook=false
    end
end})
AFSection:Button({Name="Pause / Resume",Callback=function()
    if AF.active then AF.paused=not AF.paused end
end})

-- Shortcut TP buttons for farm
local ShortcutSection = FarmSub:Section({Name="Shortcut TP",Icon="103174889897193",Side=2})
ShortcutSection:Button({Name="TP → Buy Marshmallow",Callback=function() task.spawn(function() tpToPos(MARSH_X,MARSH_Y,MARSH_Z) end) end})
ShortcutSection:Button({Name="KILL TP → Buy Marshmallow",Callback=function()
    if tpBusy then return end
    task.spawn(function() doSuicideTP({name="Buy Marshmallow",x=MARSH_X,y=MARSH_Y,z=MARSH_Z}) end)
end})

