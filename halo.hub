-- ============================================================
--   Silent Aim + Aimlock — Kiwisense UI | Halo Hub
-- ============================================================

local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/sametexe001/sametlibs/refs/heads/main/Kiwisense/Library.lua"
))()

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Player           = Players.LocalPlayer
local Camera           = workspace.CurrentCamera

-- ── State: Silent Aim ────────────────────────────────────────
local SilentAim      = false
local SilentWallbang = false
local ShowFov        = false
local DrawFov        = false
local DrawSnapline   = false
local SilentPart     = "Head"
local FovRadius      = 150
local HitChance      = 100

-- ── State: Aimlock ───────────────────────────────────────────
local AimLock      = false
local WallCheck    = false
local AimPart      = "Head"
local AimFovRadius = 150
local AimSmooth    = 0.1
local ShowAimFov   = false
local AimTarget    = nil
local RMB          = false

-- ── Drawings ─────────────────────────────────────────────────
local SilentFovCircle, SilentTracerLine, AimFovCircle
task.defer(function()
    SilentFovCircle           = Drawing.new("Circle")
    SilentFovCircle.NumSides  = 128
    SilentFovCircle.Radius    = FovRadius
    SilentFovCircle.Thickness = 1.5
    SilentFovCircle.Color     = Color3.fromRGB(255, 255, 255)
    SilentFovCircle.Filled    = false
    SilentFovCircle.Visible   = false

    SilentTracerLine              = Drawing.new("Line")
    SilentTracerLine.Thickness    = 1.5
    SilentTracerLine.Color        = Color3.fromRGB(255, 255, 255)
    SilentTracerLine.Transparency = 1
    SilentTracerLine.Visible      = false

    AimFovCircle           = Drawing.new("Circle")
    AimFovCircle.NumSides  = 128
    AimFovCircle.Radius    = AimFovRadius
    AimFovCircle.Thickness = 1.5
    AimFovCircle.Color     = Color3.fromRGB(255, 255, 255)
    AimFovCircle.Filled    = false
    AimFovCircle.Visible   = false
end)

local wpRayParams = RaycastParams.new()
wpRayParams.FilterType = Enum.RaycastFilterType.Blacklist

-- ── GC ───────────────────────────────────────────────────────
local Gc = getgc()
local function SearchGc(name)
    for _, v in pairs(Gc) do
        if type(v) == "function" then
            local ok, info = pcall(debug.getinfo, v)
            if ok and info and info.name == name then return v end
        end
    end
end

-- ── Silent Aim FOV Target ────────────────────────────────────
local function GetSilentTarget(fovPos)
    local best, bestD = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p == Player then continue end
        local ch  = p.Character
        local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum = ch and ch:FindFirstChildOfClass("Humanoid")
        local hit = ch and ch:FindFirstChild(SilentPart)
        if not hrp or not hum or not hit or hum.Health <= 0 then continue end
        local sp, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen then continue end
        local d = (fovPos - Vector2.new(sp.X, sp.Y)).Magnitude
        if d < FovRadius and d < bestD then best = p; bestD = d end
    end
    return best
end

-- ── Silent Aim Hook ──────────────────────────────────────────
local CastBlacklist = SearchGc("CastBlacklist")
local CastWhitelist = SearchGc("CastWhitelist")
if not CastBlacklist or not CastWhitelist then
    Player:Kick("Missing Function, Error code: #1")
    return
end

local OldCastBlacklist
OldCastBlacklist = hookfunction(CastBlacklist, function(...)
    local fovPos = UserInputService:GetMouseLocation()
    local Target = GetSilentTarget(fovPos)
    if Target and SilentAim then
        if math.random(1, 100) > HitChance then
            return OldCastBlacklist(...)
        end
        local args = {...}
        local hit  = Target.Character and Target.Character:FindFirstChild(SilentPart)
        if hit then
            args[2] = hit.Position - args[1]
            if SilentWallbang then
                args[3] = {Target.Character}
                return CastWhitelist(table.unpack(args))
            end
        end
        return OldCastBlacklist(table.unpack(args))
    end
    return OldCastBlacklist(...)
end)

-- ── RMB Input untuk Aimlock ──────────────────────────────────
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then RMB = true end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        RMB = false; AimTarget = nil
    end
end)

-- ── RenderStepped ────────────────────────────────────────────
RunService.RenderStepped:Connect(function()
    if not SilentFovCircle then return end
    local cam       = Camera
    local mousePos  = UserInputService:GetMouseLocation()
    local localChar = Player.Character
    local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")

    SilentFovCircle.Position = mousePos
    SilentFovCircle.Radius   = FovRadius
    SilentFovCircle.Visible  = ShowFov and DrawFov

    if SilentAim and DrawSnapline then
        local bestPos, bestD = nil, math.huge
        for _, p in pairs(Players:GetPlayers()) do
            if p == Player then continue end
            local ch  = p.Character
            local hum = ch and ch:FindFirstChildOfClass("Humanoid")
            local hit = ch and ch:FindFirstChild(SilentPart)
            if not hit or not hum or hum.Health <= 0 then continue end
            local sp, onScreen = cam:WorldToViewportPoint(hit.Position)
            if not onScreen then continue end
            local screenPos = Vector2.new(sp.X, sp.Y)
            local d = (mousePos - screenPos).Magnitude
            if d < FovRadius and d < bestD then bestD = d; bestPos = screenPos end
        end
        if bestPos then
            SilentTracerLine.From    = mousePos
            SilentTracerLine.To      = bestPos
            SilentTracerLine.Visible = true
        else
            SilentTracerLine.Visible = false
        end
    else
        SilentTracerLine.Visible = false
    end

    if not AimFovCircle then return end

    if AimTarget then
        local tHum = AimTarget.Parent and AimTarget.Parent:FindFirstChildOfClass("Humanoid")
        local sp, onScreen = cam:WorldToViewportPoint(AimTarget.Position)
        if not tHum or tHum.Health <= 0 or not onScreen then AimTarget = nil end
    end

    local shouldAim = AimLock and localRoot and RMB
    if shouldAim then
        if not AimTarget then
            local bestDist, bestPart = math.huge, nil
            for _, p in pairs(Players:GetPlayers()) do
                if p == Player then continue end
                local ch = p.Character
                local hum = ch and ch:FindFirstChildOfClass("Humanoid")
                local targetPart = ch and ch:FindFirstChild(AimPart == "Head" and "Head" or "HumanoidRootPart")
                if not targetPart or not hum or hum.Health <= 0 then continue end
                if (targetPart.Position - localRoot.Position).Magnitude > 2000 then continue end
                local sp, onScreen = cam:WorldToViewportPoint(targetPart.Position)
                if not onScreen or sp.Z <= 0 then continue end
                if WallCheck then
                    local camPos = cam.CFrame.Position
                    local dir = targetPart.Position - camPos
                    wpRayParams.FilterDescendantsInstances = {cam, Player.Character}
                    local hit = workspace:Raycast(camPos, dir.Unit * dir.Magnitude, wpRayParams)
                    if hit and not hit.Instance:IsDescendantOf(ch) then continue end
                end
                local d = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
                if d <= AimFovRadius and d < bestDist then
                    bestDist = d; bestPart = targetPart
                end
            end
            AimTarget = bestPart
        end
        if AimTarget then
            local targetCF = CFrame.lookAt(cam.CFrame.Position, AimTarget.Position)
            cam.CFrame = cam.CFrame:Lerp(targetCF, AimSmooth)
            AimFovCircle.Color = Color3.fromRGB(220, 50, 50)
        else
            AimFovCircle.Color = Color3.fromRGB(255, 255, 255)
        end
    else
        AimTarget = nil
        AimFovCircle.Color = Color3.fromRGB(255, 255, 255)
    end

    AimFovCircle.Position = mousePos
    AimFovCircle.Radius   = AimFovRadius
    AimFovCircle.Visible  = AimLock and ShowAimFov
end)

